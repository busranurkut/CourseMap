# Database — PostgreSQL connection string.
# Local dev and production both use Postgres. The easiest free option is Neon
# (https://neon.tech). Create a project and paste its connection string here.
# It looks like:
#   postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Anthropic API key — OPTIONAL.
# If provided, CourseMap generates AI-supported adaptation reports.
# If absent, CourseMap falls back to a deterministic template-based report generator.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=""

# Optional: override the Claude model used for report generation.
# Defaults to a current Claude model if unset.
ANTHROPIC_MODEL="claude-opus-4-8"
